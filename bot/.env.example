# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Supabase project URL (same as VITE_SUPABASE_URL in the web app)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key — gives the bot full DB access (bypasses RLS)
# Find it in: Supabase Dashboard → Settings → API → service_role key
# NEVER expose this key in the frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your bot's @username (without @), shown in the /link instructions
BOT_USERNAME=your_kpi_bot
