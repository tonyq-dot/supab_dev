{
  "name": "lumalance",
  "version": "0.1.0",
  "description": "Freelance platform combining lumalanc3 backend with luma-v0 frontend",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "nodemon server/index.js",
    "build": "next build",
    "start": "NODE_ENV=production node server/index.js",
    "migrate:up": "node migrations/migrate-up.js",
    "migrate:down": "node migrations/migrate-down.js",
    "seed:categories": "node scripts/seed-categories-skills.js",
    "seed:projects": "node scripts/seed-sample-projects.js",
    "seed:all": "npm run seed:categories && npm run seed:projects",
    "setup": "npm run migrate:up && npm run seed:all",
    "lint": "next lint",
    "test": "jest",
    "test:telegram": "node scripts/test-telegram-bot.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs --lines 50",
    "pm2:monitor": "pm2 monit",
    "server:restart": "sudo systemctl stop nginx && pm2 stop all && pkill -f 'npm|node' || true && sudo systemctl start nginx && npm run pm2:start",
    "server:stop": "sudo systemctl stop nginx && pm2 stop all && pkill -f 'npm|node' || true",
    "server:start": "sudo systemctl start nginx && npm run pm2:start",
    "server:status": "sudo systemctl status nginx && npm run pm2:status",
    "server:setup": "pm2 save && pm2 startup && sudo systemctl enable nginx",
    "test:reboot": "./scripts/test-reboot.sh"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@telegram-auth/react": "^1.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^10.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "next": "^14.0.0",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^9.0.1",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "telegraf": "^4.15.0",
    "typescript": "^5.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-config-next": "^14.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
